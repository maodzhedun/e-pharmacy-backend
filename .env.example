# .env.example

PORT=3000
NODE_ENV=development
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/e-pharmacy
JWT_SECRET=your_super_secret_key_here
FRONTEND_URL=http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
